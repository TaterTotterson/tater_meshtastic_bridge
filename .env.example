# The bridge always binds to 0.0.0.0.
#
# Leave this commented unless the default 8433 port is already in use.
# A non-default MESHTASTIC_BRIDGE_PORT is treated as a hard startup override.
# MESHTASTIC_BRIDGE_PORT=8434

# Optional startup-only database override. Leave blank for the platform default.
MESHTASTIC_DATABASE_PATH=

# Day-to-day bridge settings now live in the Web UI Settings tab.
# You may still use these as first-run seed values before saving in the UI.
# MESHTASTIC_DEVICE_NAME=ThinkNode M6
# MESHTASTIC_DEVICE_ADDRESS=
# MESHTASTIC_API_TOKEN=changeme
